{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["node", "eslint", "typescript", "oxc", "import", "promise"],
  "categories": {
    "correctness": "error",
    "perf": "warn",
    "style": "warn",
    "suspicious": "warn"
  },
  "rules": {
    "import/no-cycle": ["error", { "maxDepth": 3 }]
  },
  "settings": {},
  "env": {
    "builtin": true
  },
  "globals": {},
  "ignorePatterns": [],
  "options": {
    "typeAware": true,
    "typeCheck": true
  }
}
